{
  "name": "intelligent-singularity-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm verify:authenticity && pnpm readability && pnpm verify:outbound-links && next build --webpack && node scripts/measure-page-sizes.mjs && node scripts/ci-checks/bundle-budget.mjs && node scripts/ci-checks/no-third-party.mjs",
    "seed:snapshot": "node scripts/ci-checks/snapshot-seeds.mjs",
    "verify:authenticity": "pnpm seed:snapshot && node scripts/ci-checks/verify-authenticity.mjs --roadmap=.ci/seed-snapshots/roadmap.json --posts=.ci/seed-snapshots/insights.json --changelog=.ci/seed-snapshots/changelog.json --trust=.ci/seed-snapshots/trust-subprocessors.json",
    "readability": "node scripts/ci-checks/readability.mjs --path=src/lib/seed/new-pages --maxGrade=10",
    "verify:outbound-links": "node scripts/ci-checks/verify-outbound-links.mjs",
    "a11y": "node scripts/ci-checks/axe-scan.mjs",
    "seo:rich-results-checklist": "node scripts/ci-checks/seo-rich-results-checklist.mjs",
    "lighthouse": "lhci autorun",
    "start": "next start",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pre-deploy": "sh scripts/pre-deploy-checks.sh",
    "seed": "tsx src/lib/seed/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/noto-nastaliq-urdu": "^5.2.8",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/noto-sans-arabic": "^5.2.10",
    "@fontsource-variable/noto-sans-bengali": "^5.2.11",
    "@fontsource-variable/noto-sans-devanagari": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@next/env": "^16.2.3",
    "@payloadcms/db-postgres": "^3.82.1",
    "@payloadcms/next": "^3.82.1",
    "@payloadcms/richtext-lexical": "^3.82.1",
    "next": "^16",
    "next-intl": "^4.9.1",
    "nodemailer": "^8.0.5",
    "payload": "^3.82.1",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
